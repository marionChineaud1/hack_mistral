# Required for video transcription.
NUXT_MISTRAL_API_KEY=

# Shared secret used by the browser worker to call the transcription endpoint.
NUXT_TRANSCRIPTION_TOKEN=

# Public URL of the Cloudflare Browser Rendering worker.
NUXT_BROWSER_WORKER_URL=

# Absolute public origin of the companion Nuxt application (no path required).
NUXT_PUBLIC_SITE_URL=http://localhost:3000
